###############################################################################
# Normalize line endings
###############################################################################

* text=auto

###############################################################################
# Source files
###############################################################################

*.cpp  text
*.hpp  text
*.h    text
*.c    text
*.cc   text
*.cxx  text
*.hh   text
*.hxx  text
*.ipp  text
*.inl  text

###############################################################################
# Build systems
###############################################################################

CMakeLists.txt text
*.cmake        text
*.sh           text eol=lf
*.bat          text eol=crlf
*.ps1          text eol=crlf

###############################################################################
# Config / scripts
###############################################################################

*.yml   text
*.yaml  text
*.json  text
*.toml  text
*.txt   text
*.md    text

###############################################################################
# Images / assets
###############################################################################

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.ico   binary

###############################################################################
# Audio
###############################################################################

*.wav   binary
*.mp3   binary
*.ogg   binary

###############################################################################
# Fonts
###############################################################################

*.ttf   binary
*.otf   binary

###############################################################################
# Archives
###############################################################################

*.zip   binary
*.7z    binary
*.tar   binary
*.gz    binary

###############################################################################
# Executables / libraries
###############################################################################

*.exe   binary
*.dll   binary
*.so    binary
*.a     binary
*.lib   binary

###############################################################################
# Object files
###############################################################################

*.o     binary
*.obj   binary

###############################################################################
# Prevent useless diffs
###############################################################################

*.lock  -diff